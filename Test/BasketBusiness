                              0.0254232239162115,0.0138230684366999,0.0146270175075003,0.0528722456725141,
                              0.0231208911278189,0.114899997768844,0.0274107094723161,0.00690130334398807,
                              0.129303694263023,0.0364894259934032,0.122589959823627,0.0838166513872357,

def valueBasket(prices):
    # found these coefficients using R, they sum to 3 for some reason so might have to scale them down actually
    coefficients = np.array([0.0169715288319617,0.0176051127050001,0.014949193476786,0.0312771641917854,
                              0.0795660504605951,0.136309429887405,0.0335233454271418,0.0241266653513747,
                              0.100861766871424,0.0453779652982834,0.131181697802378,0.0584589566259908,
                              0.0633409038920547,0.016035175404172,0.0378748888625869,0.0482009142586522,
                              0.159667333464859,0.0502395176631227,0.0191934620275242,0.0165989852062022,
                              0.0254232239162115,0.0138230684366999,0.0146270175075003,0.0528722456725141,
                              0.0231208911278189,0.114899997768844,0.0274107094723161,0.00690130334398807,
                              0.129303694263023,0.0364894259934032,0.122589959823627,0.0838166513872357,
                              0.0896063562420657,0.0147657681606578,0.0597476906230396,0.0548519517486965,

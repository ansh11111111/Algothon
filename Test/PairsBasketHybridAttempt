                              0.0383274107379601,0.0631097229512295,0.105825667726963,0.185501713220843,
                              0.0374950025751313,0.0612135179408445,0.0734601393759236,0.0297361858128732,
                              0.0888520122074269,0.0443283357316006])

    return np.dot(prices, coefficients)


def diffFinder(prices):
    basket_price = prices[0]
    other_prices = prices[1:]

    diff = round(basket_price - valueBasket(other_prices),2)

    return(diff)


def getMyPosition (prcSoFar):
    global currentPos

    nins, nt = prcSoFar.shape
    pos = np.zeros(nins)

    if nt < MIN_HIST:
        return pos.astype(int)

    for p in PAIRS:
        i, j, beta, alpha = p['i'], p['j'], p['beta'], p['alpha']

        price_i_hist = prcSoFar[i, :]
        price_j_hist = prcSoFar[j, :]
        spread_hist = price_i_hist - beta * price_j_hist - alpha

        recent = spread_hist[-Z_LOOKBACK:]
        mu = recent.mean()
        sd = recent.std()
        if sd < 1e-8:
            continue
        z = (spread_hist[-1] - mu) / sd

        signal = -z

        price_i = prcSoFar[i, -1]
        pos_i_shares = signal * DOLLAR_BUDGET / price_i
        pos_j_shares = -beta * pos_i_shares

        pos[i] += pos_i_shares
        pos[j] += pos_j_shares

    currentPos = np.array([int(x) for x in pos])

    diffs = []
    for i in range(3):   # finds the diffs for the past 3 days
        day_prices = prcSoFar[:,-i-1]
        diff = diffFinder(day_prices)
        diffs.append(diff)

    avg_diff = np.mean(diffs)

    if avg_diff > 0: # basket is overvalued
        currentPos[0] += 10 # buy ONE basket, can experiment with quantities
        currentPos[1:] -= 10 # sell ONE of everything else
    elif avg_diff < 0: # basket is undervalued
        currentPos[0] -= 10
        currentPos[1:] += 10

    return currentPos

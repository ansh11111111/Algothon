import numpy as np

nInst = 51

# ---- Core pairs strategy parameters (tuned via grid search in sweep.py / strategies.py) ----
Z_LOOKBACK = 40
PAIR_DOLLAR_BUDGET = 8000
MIN_HIST = Z_LOOKBACK + 2

# ---- Kalman filter parameters for time-varying hedge ratio (beta, alpha) ----
# State: x_t = [beta_t, alpha_t], random-walk transition x_t = x_{t-1} + w_t
# Observation: price_i[t] = beta_t * price_j[t] + alpha_t + v_t
# delta controls how fast beta/alpha are allowed to drift (process noise scale).
# Smaller delta -> smoother/slower-adapting beta. This mirrors the classic
# Kalman pairs-trading setup (Chan, "Algorithmic Trading").
KALMAN_DELTA = 1e-4
KALMAN_VE = 1e-3          # observation noise variance (measurement noise)
KALMAN_WARMUP = 30        # min points before trusting the filtered beta/alpha

MIN_HIST = max(MIN_HIST, KALMAN_WARMUP + 2)

# Indices (into the 51-instrument price array) of names with train-period lag-1

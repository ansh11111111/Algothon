# MDGI, MSDP, AETS, LSST, ULXY, HUXZ
RANGE_BOUND_IDX = [16, 49, 23, 44, 45, 27, 20, 14, 48, 22, 12, 39, 2, 40, 8]

RSI_LOOKBACK = 7
RSI_VOL_LOOKBACK = 10
OVERLAY_BUDGET = 55000

# Each pair's beta/alpha here are used ONLY as the Kalman filter's initial prior
# (fit on training data). From there the filter adapts beta_t/alpha_t online as
# new prices arrive, instead of keeping them frozen for the whole backtest.
PAIRS = [

def _kalman_hedge_ratio(y, x, beta0, alpha0):
    """
    Run a 2-state (beta, alpha) Kalman filter over the full history of a pair,
    modelling y_t = beta_t * x_t + alpha_t + v_t, with beta_t/alpha_t following
    a random walk. Returns the filtered (beta, alpha) at the final timestep and
    the innovation (prediction error) variance at the final step, which is used
    downstream as an adaptive replacement for the rolling z-score std.

    y, x: 1D arrays of prices (same length), y = instrument i, x = instrument j.
    beta0, alpha0: prior state mean, from the original offline regression fit.
    """
    n = len(y)
    state = np.array([beta0, alpha0], dtype=float)
    # Prior state covariance: fairly loose, since beta0/alpha0 were fit offline
    # and may be stale by the time this pair is actually traded live.
    P = np.eye(2) * 1.0
    Q = np.eye(2) * KALMAN_DELTA   # process noise (drift allowed per step)
    R = KALMAN_VE                  # observation noise

    innovation = 0.0
    innovation_var = R

    for t in range(n):
        H = np.array([x[t], 1.0])  # observation matrix: y_t = H @ state + noise

        # Predict step (random walk -> state unchanged, covariance inflates)
        P = P + Q

        # Update step
        y_pred = H @ state
        innovation = y[t] - y_pred
        S = H @ P @ H + R            # innovation variance (scalar since 1D obs)
        K = (P @ H) / S              # Kalman gain
        state = state + K * innovation
        P = P - np.outer(K, H) @ P

        innovation_var = S

    beta_t, alpha_t = state
    return beta_t, alpha_t, innovation, innovation_var


def pairsDollarSignal(prcSoFar):
    """Raw per-instrument dollar exposure from the 20-pair stat-arb book (pre share-rounding).
    Hedge ratios (beta, alpha) are now tracked online via a Kalman filter instead of being
    frozen at their offline-fit values, and the spread z-score uses the filter's own
    innovation variance instead of a fixed rolling window std."""
    nins, nt = prcSoFar.shape
    dollar = np.zeros(nins)
    if nt < MIN_HIST:
        return dollar

    for p in PAIRS:
        i, j, beta0, alpha0 = p['i'], p['j'], p['beta'], p['alpha']
        y = prcSoFar[i, :]
        x = prcSoFar[j, :]

        beta_t, alpha_t, innovation, innovation_var = _kalman_hedge_ratio(
            y, x, beta0, alpha0
        )

        if innovation_var < 1e-8:
            continue

        # z-score of today's spread surprise, using the Kalman filter's own
        # adaptive innovation std in place of the old rolling-40-day std.
        z = innovation / np.sqrt(innovation_var)
        signal = -z

        price_i = prcSoFar[i, -1]
        price_j = prcSoFar[j, -1]
        pos_i_shares = signal * PAIR_DOLLAR_BUDGET / price_i
        pos_j_shares = -beta_t * pos_i_shares

        dollar[i] += pos_i_shares * price_i
        dollar[j] += pos_j_shares * price_j

    return dollar


def rsiDollarSignal(prcSoFar):
    """Per-instrument RSI mean-reversion signal (fades overbought/oversold), inverse-vol
    weighted. Returns a raw (un-budgeted) dollar-like signal to be normalized by the caller."""
    nins, nt = prcSoFar.shape
    if nt < RSI_LOOKBACK + 2:
        return np.zeros(nins)

    deltas = np.diff(prcSoFar[:, -(RSI_LOOKBACK + 1):], axis=1)
    gains = np.clip(deltas, 0, None).mean(axis=1)
    losses = np.clip(-deltas, 0, None).mean(axis=1)
    losses = np.where(losses < 1e-8, 1e-8, losses)
    rs = gains / losses
    rsi = 100 - 100 / (1 + rs)

    rets = np.diff(np.log(prcSoFar), axis=1)
    vl = min(RSI_VOL_LOOKBACK, rets.shape[1])
    vol = np.maximum(rets[:, -vl:].std(axis=1), 1e-8)

    signal = -(rsi - 50) / vol   # fade: overbought (RSI>50) -> short, oversold -> long

    mask = np.zeros(nins)
    mask[RANGE_BOUND_IDX] = 1.0
    return signal * mask


def getMyPosition(prcSoFar):
    nins, nt = prcSoFar.shape
    if nt < MIN_HIST:
        return np.zeros(nins).astype(int)

    pairs_d = pairsDollarSignal(prcSoFar)

    rsi_raw = rsiDollarSignal(prcSoFar)
    gross = np.sum(np.abs(rsi_raw))
    rsi_d = (rsi_raw / gross * OVERLAY_BUDGET) if gross > 0 else rsi_raw

    combined_dollar = pairs_d + rsi_d
    return (combined_dollar / prcSoFar[:, -1]).astype(int)
